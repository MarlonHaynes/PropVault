
# ══════════════════════════════════════════════════════════════════════════════
# PropVault v2 — Environment Variables
# Copy this file to .env.local and fill in your values.
# The app runs in DEMO MODE without any keys — no setup needed.
# ══════════════════════════════════════════════════════════════════════════════

# ── Firebase (Required for live listings, auth, and image upload) ─────────────
# Create a project at https://console.firebase.google.com
# Go to Project Settings → Your Apps → Web App → Config

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Admin Access ──────────────────────────────────────────────────────────────
# Comma-separated Firebase UIDs that have admin access to the admin panel.
# After you log in for the first time, go to /admin — the page will show your UID.
# Copy that UID here and re-deploy.

NEXT_PUBLIC_ADMIN_UIDS=your-firebase-uid-here

# ── Google Maps (Optional — enables interactive property map) ─────────────────
# Get a key at https://console.cloud.google.com
# Enable: Maps JavaScript API, Geocoding API
# Without this key, the map shows a styled placeholder with a link to Google Maps.

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Stripe (Optional — enables real deposit payments) ─────────────────────────
# Get keys at https://dashboard.stripe.com
# Without these, payments are mocked (always succeed after 1.5s delay).

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# QUICK START — DEMO MODE
# ══════════════════════════════════════════════════════════════════════════════
# Just run: npm install && npm run dev
# Log in with "Continue as Demo User" on the login page.
# The demo user is automatically an admin — access /admin to manage listings.
# Uploaded images are stored as object URLs (browser memory only in demo mode).
# ══════════════════════════════════════════════════════════════════════════════

# ── FIREBASE SETUP CHECKLIST (when you're ready to go live) ──────────────────
# 1. Create Firebase project + enable Authentication (Email/Password)
# 2. Create Firestore database in production mode
# 3. Create Storage bucket
# 4. Deploy Firestore rules:   firebase deploy --only firestore:rules
# 5. Deploy Storage rules:     firebase deploy --only storage
# 6. Add your Firebase config values above
# 7. Log in to the site, note your UID from /admin
# 8. Add your UID to NEXT_PUBLIC_ADMIN_UIDS
# 9. Go to /admin and click "Seed DB" to populate Firestore with the 30 listings
# ═════════════════════════════════════════════════════════════════════════════

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# App runs in demo mode when these are missing — no real keys required
